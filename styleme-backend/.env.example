# StyleMe - Variables de Entorno (ejemplo)
# Copiar este archivo como .env y completar los valores

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=styleme_db

# JWT
JWT_SECRET_KEY=styleme_super_secret_key_2025
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# Rutas ML y uploads
ML_MODELS_PATH=./models
UPLOADS_PATH=./uploads

# Configuración de imágenes
MAX_IMAGE_SIZE_MB=5

# Rate limiting
MAX_REQUESTS_PER_MINUTE=10

# API
API_VERSION=v1
