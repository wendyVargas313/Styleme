# StyleMe - Variables de Entorno (ejemplo)
# Copiar este archivo como .env y completar los valores

# MongoDB
# Con Docker este valor lo sobrescribe docker-compose.yml (mongodb://mongo:27017).
# Solo aplica en instalacion manual sin Docker:
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=styleme_db

# JWT
JWT_SECRET_KEY=CAMBIAR_POR_UNA_CLAVE_PROPIA_Y_LARGA
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# Rutas ML y uploads
# En Docker lo sobrescribe el compose (/app/models). Sin Docker, los modelos
# estan en la raiz del repo:
ML_MODELS_PATH=../
UPLOADS_PATH=./uploads

# Configuración de imágenes
MAX_IMAGE_SIZE_MB=5

# Rate limiting
MAX_REQUESTS_PER_MINUTE=10

# API
API_VERSION=v1

# CORS - orígenes permitidos, separados por comas (fallback: localhost:8000)
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
